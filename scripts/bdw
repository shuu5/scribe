#!/usr/bin/env bash
# bdw — scribe consume shim。logic ゼロの薄い委譲で、canonical bdw(beads-bdw plugin の
# 単一 SSOT)へ exec する。直列化(flock)・fail-closed・lock-dir 解決の本体ロジックは一切持たない。
#
# CUTOVER (orch-wvd Step3 / sc-vae・2026-06-27): 本ファイルは従来 106 行の flock serializer 本体
#   (uns un-gmq 由来・scribe へ re-home sc-jr0・line43 で lib/scribe-lib.sh を source)だったが、
#   3 copy drift(uns / scriptorium / scribe)撲滅の grill 合意(orch-wvd grill 2026-06-23 で admin+人間が
#   (b)=canonical plugin consume を ratify)により canonical bin/bdw を consume する薄い shim へ載せ替えた。
#   Step1(scriptorium)/Step2(uns) は landed 済で本 Step3 が最後(最も結合が強いので最後)。全 call site の
#   `scripts/bdw <subcmd>` 形は不変。本 shim の実行ロジック(set/_CANON/if/exec)は plugin の
#   templates/bdw-shim と byte-identical に保ち、再 sync を容易にする(SSOT=plugin・ここはコピー)。
#
# 解決順: BEADS_BDW(明示) → 既定 plugin 標準配置($HOME/.claude/plugins/beads-bdw/bin/bdw)。canonical が
#   無い/実行不可なら fail-closed(exit 1)。素通しすると直列化が外れ lost-update が黙って復活するため、
#   loud に停止して bd write を実行しない(旧実装の /tmp fail-open fallback は廃止＝静かな lost-update 復活が最悪)。
#
# env 互換: 旧 bdw の BDW_LOCK_DIR / BDW_LOCK_TIMEOUT / BDW_BD_BIN は exec で canonical に継承される
#   ため従来どおり効く(これら ENV の SSOT は canonical 側)。lock_dir 既定 = $HOME/.cache/bdw-locks
#   (canonical が解決・`scripts/bdw lock-dir` で参照可＝gen-sandbox の allowWrite が consume する contract)。
set -uo pipefail

_CANON="${BEADS_BDW:-$HOME/.claude/plugins/beads-bdw/bin/bdw}"
if [ ! -x "$_CANON" ]; then
  echo "bdw-shim: canonical bdw not found or not executable: $_CANON" >&2
  echo "bdw-shim: set BEADS_BDW to the canonical bin/bdw, or install the beads-bdw plugin." >&2
  echo "bdw-shim: fail-closed — bd write NOT run (直列化を外して実行はしない)。" >&2
  exit 1
fi
exec "$_CANON" "$@"
