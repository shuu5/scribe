#!/bin/bash
# cld-spawn - Start a new Claude Code session in a new tmux window
#
# 使い方（オプション一覧・PROMPT の渡し方・'-' 始まり PROMPT の '--' 区切り）は
# usage() 関数 ／ `cld-spawn --help` を SSOT とする。ドリフト防止のため、この header に
# オプション一覧を二重に持たない（usage() を読むこと）。
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
# shellcheck source=./session-name.sh
source "$SCRIPT_DIR/session-name.sh"
# shellcheck source=./lib/session-env.sh
source "$SCRIPT_DIR/lib/session-env.sh"

# usage を表示（冒頭コメントの Usage と同内容）。--help は stdout、エラー時は stderr へ。
usage() {
    cat <<EOF
Usage:
  $(basename "$0") [OPTIONS] [PROMPT]

Options:
  --cd DIR            起動セッションの作業ディレクトリ（既定: 現在の cwd）
  --env-file PATH     起動前に source する env ファイル（既定: ~/.cld-env）
  --window-name NAME  tmux window 名を明示指定
  --session NAME      spawn 先 tmux session を指定（session=project 対称性の write 側）。
                      宛先 session が無ければ detached で新規作成する（create-if-absent）。
                      window 再利用の探索もこの session 内に限定される。省略時は現在の
                      session が spawn 先（再利用探索も現在 session 内に限定＝session-scope）。
  --bd-id ID          bd issue id 連動命名（wt-<id>）
  --force-new         既存 window を再利用せず必ず新規作成
  --timeout N         inject 待機秒（正の整数・既定: 60）
  --model MODEL       cld に渡す --model
  --effort LEVEL      cld→claude へ透過する --effort（low|medium|high|xhigh|max）。
                      値は verbatim 透過＝validate は呼び側の責務（claude 側が fail-loud）。
                      spawn 起動にのみ有効。
  --disallowed-tools TOOLS
                      cld→claude へ透過する --disallowed-tools（空白/カンマ区切りの
                      ツール名。複数指定で累積）。無人 window で AskUserQuestion 等の
                      対話 tool を物理封鎖する用途。spawn 起動にのみ有効。
  --inject-existing WINDOW
                      spawn せず既存の tmux window へ PROMPT を注入する（inject-file +
                      read-back 受理確認を再利用）。PROMPT 必須。spawn 専用オプション
                      （--model / --effort / --disallowed-tools / --cd / --env-file /
                      --window-name / --bd-id / --force-new）とは併用不可。
  -h, --help          この usage を表示して終了

PROMPT は positional arg ではなく、起動後に wait-ready + inject-file で送達する。
PROMPT が '-' で始まる場合は '--' を置いて区切る（例: $(basename "$0") -- "-から始まる prompt"）。
EOF
}

# 値取りオプションの値スロットを検証して fail-loud にする（全値取りオプション共通の SSOT）:
#   - 空（値なし）            → エラー（従来挙動）
#   - '-' で始まるトークン    → 直後のオプションを値として取りこぼした可能性が高いので拒否する。
#                               cld-spawn の値取りオプションは '-' 始まりの値を受け付けない。
#                               '--' 終端より前で値スロットへ来た '-...' は打ち間違い／別オプションの
#                               誤吸着とみなし、ここで止めて誤った window 名・env-file 等での spawn を防ぐ。
# $1 = オプション名（エラー表示用） / $2 = 値スロット（未指定なら空文字）
require_value() {
    local opt="$1" val="${2-}"
    if [[ -z "$val" ]]; then
        echo "Error: $opt に値を指定してください" >&2
        exit 1
    fi
    if [[ "$val" == -* ]]; then
        echo "Error: $opt の値が '-' で始まっています（次のオプションの取りこぼし防止のため拒否）: $val" >&2
        echo "       値ではなくオプションを書いた可能性があります。値が本当に必要なら正しい順序で指定してください。" >&2
        exit 1
    fi
}

# deliver_prompt <window> <prompt>
#   既存の inject-file + read-back（--confirm-receipt）機構で PROMPT を有界リトライ送達する共通ヘルパ。
#   spawn 経路（新規 window）と --inject-existing 経路（既存 window）の両方から呼ぶ（SSOT・DRY）。
#   welcome race で初回 paste が drop しても read-back が未着を検出し、settle 後 --clear-first で再送。
#   inject-file は tmux 層成功だけでは成功扱いにしない（claude の受理を read-back で確認）ため、
#   非 0 が返るのは「真に未着」のとき＝偽 "prompt injected" を出さない。成功で 0、失敗で非 0 を返す。
deliver_prompt() {
    local _win="$1" _prompt="$2"
    local _pf
    _pf=$(mktemp /tmp/cld-spawn-prompt-XXXXXX.txt)
    printf '%s' "$_prompt" > "$_pf"

    # CONFIRM_BUDGET: read-back が「受理」を確認する 1 試行あたりの猶予秒（cld-spawn 既定 10s）。
    local _confirm_budget="${CLD_CONFIRM_BUDGET:-10}"
    local _max_attempts="${CLD_INJECT_ATTEMPTS:-3}"
    local _ok=false _attempt _rc
    # inject-file の exit code 意味論（SSOT=session-comm.sh usage の Exit codes 表・ccs-3bj）:
    #   0 = 受理（clean submit）              → terminal-success（再送しない）
    #   5 = queued（busy 宛先で CC message queue へ着弾）→ terminal-success（**再送禁止**。再送は重複 queue＝
    #       --clear-first では CC の message queue を dequeue できず 1 copy ずつ純増する・orch-uwv6 実測 4 重複）。
    #       DELIVER_QUEUED=true にして呼出側が clean submit と queued を判別できるようにする。
    #   その他非 0（1/2/4 等）= 未着/失敗       → 有界リトライ（attempt>1 は --clear-first で再送）
    DELIVER_QUEUED=false
    for _attempt in $(seq 1 "$_max_attempts"); do
        local _clear=()
        if [[ "$_attempt" -gt 1 ]]; then _clear=(--clear-first); fi
        _rc=0
        "$SCRIPT_DIR/session-comm.sh" inject-file "$_win" "$_pf" \
                --wait "$WAIT_TIMEOUT" --confirm-receipt "$_confirm_budget" ${_clear[@]+"${_clear[@]}"} || _rc=$?
        if [[ "$_rc" -eq 0 ]]; then
            _ok=true
            break
        elif [[ "$_rc" -eq 5 ]]; then
            # queued: 積極証拠つきで CC message queue へ着弾済み＝送達成功。再送すると重複するため即 break。
            _ok=true
            DELIVER_QUEUED=true
            break
        fi
        if [[ "$_attempt" -lt "$_max_attempts" ]]; then sleep 1; fi
    done

    rm -f "$_pf"
    $_ok
}

# _disallowed_reuse_error
#   --disallowed-tools 指定時に既存 window 再利用が起きた場合の fail-loud メッセージ（reuse 2 箇所で共用）。
#   既に起動済みの window には封鎖を後付けできない＝黙って未封鎖 window を再利用し exit 0（偽成功）にしない
#   ための fail-closed（gate round-1 CONFIRMED #3 の修正）。
_disallowed_reuse_error() {
    echo "Error: 既存 window '$WINDOW_NAME' には --disallowed-tools を後付けできません（既に起動済み・封鎖が適用されない）。" >&2
    echo "       封鎖付きで起動するには対象 window を閉じるか、別の --window-name を指定してください。" >&2
}

# _win_match_count <window>
#   bare 名指定が全 session 横断で何個の window に一致するかを返す（stdout に件数）。
#   --inject-existing の曖昧検出用（gate round-1 CONFIRMED #4）。session:… 形式は呼び出し側で対象外にする。
_win_match_count() {
    tmux list-windows -a -F '#{window_name}' 2>/dev/null | grep -Fxc "$1" || true
}

# _win_exists <window>
#   指定 tmux window が存在するか（bare 名 / session:window / session:index の各形式）を判定する。
#   --inject-existing の事前チェック用。存在で 0、不在で 1。
_win_exists() {
    local _w="$1"
    if [[ "$_w" == *:* ]]; then
        tmux list-windows -a -F '#{session_name}:#{window_name}' 2>/dev/null | grep -qFx "$_w" && return 0
        tmux list-windows -a -F '#{session_name}:#{window_index}' 2>/dev/null | grep -qFx "$_w" && return 0
        return 1
    fi
    tmux list-windows -a -F '#{window_name}' 2>/dev/null | grep -qFx "$_w"
}

CWD="$(pwd)"
CD_SPECIFIED=false
ENV_FILE=""
WINDOW_NAME=""
TARGET_SESSION_OPT=""  # --session の明示値（空=未指定＝現在 session が spawn 先）
BD_ID=""
FORCE_NEW=0
WAIT_TIMEOUT=60
CLD_MODEL=""
CLD_EFFORT=""         # cld→claude へ透過する --effort（空=未指定＝settings/model 既定に委ねる）
DISALLOWED_TOOLS=()   # cld→claude へ透過する --disallowed-tools のトークン列（空=未指定）
INJECT_EXISTING=""    # 非空なら「spawn せず既存 window へ inject」モード（値=対象 window）
DELIVER_QUEUED=false  # deliver_prompt が queued（inject-file exit 5）で成功したかを呼出側へ伝える（ccs-3bj）

# Parse options
while [[ $# -gt 0 ]]; do
    case "$1" in
        --cd)
            require_value --cd "${2-}"
            CWD="$2"
            CD_SPECIFIED=true
            shift 2
            ;;
        --env-file)
            require_value --env-file "${2-}"
            ENV_FILE="$2"
            shift 2
            ;;
        --window-name)
            require_value --window-name "${2-}"
            WINDOW_NAME="$2"
            shift 2
            ;;
        --session)
            require_value --session "${2-}"
            # tmux session 名の制約（':' '.' 不可）+ 本スクリプトが '=' 前置 exact match で
            # 参照するため、英数字・'-'・'_' のみ許容（先頭は英数字）。fail-loud。
            if ! [[ "$2" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]]; then
                echo "Error: --session 名は英数字・'-'・'_' のみ（先頭は英数字）: $2" >&2
                exit 1
            fi
            TARGET_SESSION_OPT="$2"
            shift 2
            ;;
        --bd-id)
            require_value --bd-id "${2-}"
            BD_ID="$2"
            shift 2
            ;;
        --force-new)
            FORCE_NEW=1
            shift
            ;;
        --timeout)
            require_value --timeout "${2-}"
            WAIT_TIMEOUT="$2"
            if ! [[ "$WAIT_TIMEOUT" =~ ^[1-9][0-9]*$ ]]; then
                echo "Error: --timeout には正の整数を指定してください" >&2
                exit 1
            fi
            shift 2
            ;;
        --model)
            require_value --model "${2-}"
            CLD_MODEL="$2"
            shift 2
            ;;
        --effort)
            require_value --effort "${2-}"
            CLD_EFFORT="$2"
            shift 2
            ;;
        --disallowed-tools)
            require_value --disallowed-tools "${2-}"
            # 値は**分割せず verbatim に 1 要素**として蓄える（cld 側で split しない）。
            # 理由（gate round-1 CONFIRMED fail-open の修正）: claude の --disallowed-tools は 1 argv 内を
            # **括弧を認識して** space/comma で分割する（例 'Bash(git push:*)' や 'Bash(* --version)' は
            # 内部空白を含む単一 spec が正典・`claude --help` の例 "Bash(git *) Edit" が示す）。cld 側で
            # read -ra 等の空白 split を掛けると内部空白を持つ spec が壊れた断片に割れ、claude が非合致 rule
            # として黙殺 → 意図した block が沈黙して効かない silent fail-open になる（cld は
            # --dangerously-skip-permissions 起動ゆえ唯一の hard block が失効する重大事象）。よって値は
            # そのまま 1 argv として透過し、分割は claude に委ねる。複数 spec は 1 つの値に空白/カンマ区切りで
            # まとめる（claude が分割）か、--disallowed-tools を複数回指定して累積する。
            DISALLOWED_TOOLS+=("$2")
            shift 2
            ;;
        --inject-existing)
            require_value --inject-existing "${2-}"
            INJECT_EXISTING="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --)
            # オプション終端: 以降は '-' で始まっても PROMPT として扱う
            shift
            break
            ;;
        -*)
            # 未知オプションを fail-loud で拒否（PROMPT に流して誤 spawn しない）
            echo "Error: 未知のオプション: $1" >&2
            usage >&2
            exit 1
            ;;
        *)
            break
            ;;
    esac
done

# tmux check（--help / 未知オプション判定の後＝help は tmux 外でも機能する）
if [[ -z "${TMUX:-}" ]]; then
    echo "Error: tmux内で実行してください" >&2
    exit 1
fi

# 残りの引数を PROMPT として結合（spawn / inject-existing 両モード共通・先に確定させる）
PROMPT=""
if [[ $# -gt 0 ]]; then
    PROMPT="$*"
fi

# --- inject-existing モード: spawn せず既存 window へ PROMPT を注入する（inject-file + read-back 再利用） ---
# spawn（新規 window 作成）を一切行わず、既存 window に対して deliver_prompt を回すだけ。env-file の
# デフォルト解決より前に分岐して、spawn 専用オプションの誤併用を早期に fail-loud で弾く。
if [[ -n "$INJECT_EXISTING" ]]; then
    # spawn 専用オプションとの併用を拒否（意味論的に無関係＝取り違えを黙って無視せず検出する）。
    # ここで ENV_FILE はまだ raw（--env-file を明示した時のみ非空）＝明示併用のみを検出できる。
    _conflict=""
    [[ -n "$CLD_MODEL" ]] && _conflict+=" --model"
    [[ -n "$CLD_EFFORT" ]] && _conflict+=" --effort"
    [[ "${#DISALLOWED_TOOLS[@]}" -gt 0 ]] && _conflict+=" --disallowed-tools"
    $CD_SPECIFIED && _conflict+=" --cd"
    [[ -n "$ENV_FILE" ]] && _conflict+=" --env-file"
    [[ -n "$WINDOW_NAME" ]] && _conflict+=" --window-name"
    [[ -n "$TARGET_SESSION_OPT" ]] && _conflict+=" --session"
    [[ -n "$BD_ID" ]] && _conflict+=" --bd-id"
    [[ "$FORCE_NEW" -eq 1 ]] && _conflict+=" --force-new"
    if [[ -n "$_conflict" ]]; then
        echo "Error: --inject-existing は spawn 専用オプションと併用できません:${_conflict}" >&2
        exit 1
    fi
    if [[ -z "$PROMPT" ]]; then
        echo "Error: --inject-existing は PROMPT が必須です（注入する内容が無い）" >&2
        exit 1
    fi
    if ! _win_exists "$INJECT_EXISTING"; then
        echo "Error: 既存 window が見つかりません: $INJECT_EXISTING" >&2
        exit 1
    fi
    # bare 名（session 非指定）が全 session 横断で複数一致すると、resolve_target が先頭一致で
    # 意図しない window へ注入し 'prompt injected' と偽成功を返す（#4 修正）。曖昧なら fail-loud で
    # session:window 形式の明示を促す（session:… 明示時はこのチェックの対象外）。
    if [[ "$INJECT_EXISTING" != *:* ]]; then
        _match_n=$(_win_match_count "$INJECT_EXISTING")
        if [[ "${_match_n:-0}" -gt 1 ]]; then
            echo "Error: window 名 '$INJECT_EXISTING' が複数 session に一致します（${_match_n}件）。session:window 形式で対象を明示してください。" >&2
            exit 1
        fi
    fi
    if deliver_prompt "$INJECT_EXISTING" "$PROMPT"; then
        if $DELIVER_QUEUED; then
            echo "prompt injected → '$INJECT_EXISTING' (existing, queued: busy 宛先の CC message queue へ着弾・再送なし)"
        else
            echo "prompt injected → '$INJECT_EXISTING' (existing)"
        fi
        exit 0
    fi
    echo "Error: プロンプトの送達に失敗しました（inject-existing: $INJECT_EXISTING／read-back 未確認）" >&2
    exit 1
fi

# --env-file 未指定時は CLD_ENV_FILE 環境変数、次に ~/.cld-env をデフォルトとして使用
ENV_FILE="${ENV_FILE:-${CLD_ENV_FILE:-$HOME/.cld-env}}"
# --env-file のチルダ展開（存在チェックは不要: 不在時は source が 2>/dev/null で無視）
if [[ -n "$ENV_FILE" ]]; then
    ENV_FILE="${ENV_FILE/#\~/$HOME}"
fi

# --cd 指定時のみチルダ展開・正規化・存在チェックを実行
if $CD_SPECIFIED; then
    CWD="${CWD/#\~/$HOME}"
    CWD="$(realpath -m "$CWD")"
    if [[ ! -d "$CWD" ]]; then
        echo "Error: ディレクトリが存在しません: $CWD" >&2
        exit 1
    fi
fi

# spawn 先 session の解決（--session 明示 > 現在 session）。window の生成・再利用探索・
# 存在検証・manifest 記録・プロンプト送達はすべてこの TARGET_SESSION スコープで行う
# （session-scope 化・ccs-y9h。現状の「current session に生成するのに再利用は全 session 横断」
# という非対称が、別プロジェクト session の同名 window を掴む topology drift の一因だった）。
if [[ -n "$TARGET_SESSION_OPT" ]]; then
    TARGET_SESSION="$TARGET_SESSION_OPT"
else
    TARGET_SESSION="$(tmux display-message -p '#{session_name}')"
    if [[ -z "$TARGET_SESSION" ]]; then
        echo "Error: 現在の tmux session 名を解決できませんでした" >&2
        exit 1
    fi
fi

# ウィンドウ名の解決順:
#   1. --window-name 明示（最優先）
#   2. --bd-id 指定時は wt-<id>（fleet-monitor の worker↔window 完全一致照合の producer 規約）
#   3. 意味論的命名 generate_window_name（git 状態由来）
#   4. 時刻ベースフォールバック wt-HHMMSS-$$
if [[ -z "$WINDOW_NAME" && -n "$BD_ID" ]]; then
    WINDOW_NAME=$(spawn_window_name "$BD_ID")
fi
if [[ -z "$WINDOW_NAME" ]]; then
    if ! WINDOW_NAME=$(generate_window_name wt "$CWD" "$CWD" 2>/dev/null); then
        WINDOW_NAME="wt-$(date +%H%M%S)-$$"
    fi
fi

# Build launcher script to avoid shell quoting issues with tmux
# cld は引数なしで起動（プロンプトは後から inject-file で送達）
LAUNCHER=$(mktemp /tmp/cld-spawn-XXXXXX.sh)
chmod +x "$LAUNCHER"

# cld 起動行を組み立てる（CLD_PATH: テスト時のスタブ差し替え用・本番では未設定 → $SCRIPT_DIR/cld）。
# --disallowed-tools は claude 側で可変長 <tools...> ゆえ必ず**末尾**に置く（後続トークンが無い＝
# variadic が余計な語を吸収しない）。各ツール名を個別に %q して cld→claude へ透過する。
_CLD_LINE=$(printf '%q' "${CLD_PATH:-$SCRIPT_DIR/cld}")
if [[ -n "${CLD_MODEL:-}" ]]; then
    _CLD_LINE+=$(printf ' --model %q' "${CLD_MODEL}")
fi
if [[ -n "${CLD_EFFORT:-}" ]]; then
    _CLD_LINE+=$(printf ' --effort %q' "${CLD_EFFORT}")
fi
if [[ "${#DISALLOWED_TOOLS[@]}" -gt 0 ]]; then
    _CLD_LINE+=' --disallowed-tools'
    for _t in "${DISALLOWED_TOOLS[@]}"; do
        _CLD_LINE+=$(printf ' %q' "$_t")
    done
fi

{
    echo '#!/bin/bash'
    if [[ -n "$ENV_FILE" ]]; then
        echo "source $(printf '%q' "$ENV_FILE") 2>/dev/null || true"
    fi
    echo "cd $(printf '%q' "$CWD") || exit 1"
    echo "$_CLD_LINE"
    # Keep window open on error for diagnosis
    cat <<'TRAP'
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "=== claude exited with code $EXIT_CODE ==="
    echo "Press Enter to close, or Ctrl-C to keep open."
    read -r || sleep 60
fi
TRAP
} > "$LAUNCHER"

# 同一 canonical_context の既存 window 再利用（--force-new 未指定時・TARGET_SESSION 内のみ）
if [[ "$FORCE_NEW" -eq 0 ]]; then
    _EXISTING=$(find_existing_window "$WINDOW_NAME" "$TARGET_SESSION")
    if [[ -n "$_EXISTING" ]]; then
        # --disallowed-tools は起動時にしか適用できない（既存 window には後付け不可）。
        # 黙って未封鎖 window を再利用し exit 0（偽成功）にせず fail-loud で止める（#3 fail-open 修正）。
        if [[ "${#DISALLOWED_TOOLS[@]}" -gt 0 ]]; then
            rm -f "$LAUNCHER"
            _disallowed_reuse_error
            exit 1
        fi
        rm -f "$LAUNCHER"
        tmux select-window -t "$_EXISTING"
        echo "reusing existing window: $_EXISTING ($WINDOW_NAME)"
        exit 0
    fi
fi

# 排他ロックで TOCTOU を防止しつつ new-window を実行
mkdir -p "$(dirname "$SESSION_LOCK_FILE")"
exec 200>"$SESSION_LOCK_FILE"
if ! flock -w 5 200; then
    rm -f "$LAUNCHER"
    echo "Error: ウィンドウ作成ロックを取得できませんでした" >&2
    exit 1
fi

# ロック内で再チェック（競合プロセスが先に作成した可能性・TARGET_SESSION 内のみ）
if [[ "$FORCE_NEW" -eq 0 ]]; then
    _EXISTING=$(find_existing_window "$WINDOW_NAME" "$TARGET_SESSION")
    if [[ -n "$_EXISTING" ]]; then
        if [[ "${#DISALLOWED_TOOLS[@]}" -gt 0 ]]; then
            exec 200>&-
            rm -f "$LAUNCHER"
            _disallowed_reuse_error
            exit 1
        fi
        exec 200>&-
        rm -f "$LAUNCHER"
        tmux select-window -t "$_EXISTING"
        echo "reusing existing window: $_EXISTING ($WINDOW_NAME)"
        exit 0
    fi
fi

# 宛先 session が無ければ detached で新規作成し、その初期 window として起動する
# （create-if-absent・orch-thgx 追補4: 1-window session の admin kill は tmux session ごと
# 破棄されるため、次回 spawn が session を再建できる必要がある）。has-session/new-window の
# session 参照は '=' 前置の exact match（tmux 既定の prefix match による誤爆防止）。
# この check-then-create は上の flock 区間内＝並列 spawn の duplicate session race も排除される。
if tmux has-session -t "=$TARGET_SESSION" 2>/dev/null; then
    tmux new-window -t "=$TARGET_SESSION:" -n "$WINDOW_NAME" "bash '$LAUNCHER'; rm -f '$LAUNCHER'"
else
    tmux new-session -d -s "$TARGET_SESSION" -n "$WINDOW_NAME" "bash '$LAUNCHER'; rm -f '$LAUNCHER'"
    # hold（番兵）window の常設（orch-oktg）: tmux は window 0 枚の session を許さず、最後の window の
    # kill-window は session ごと破棄する（remain-on-exit は明示 kill に無力・isolated socket 実測
    # 2026-07-15）。window 1 枚運用では respawn（kill-window → 再 spawn）のたびに session 消滅 →
    # attach client 蹴り出し + 宛先 'session:window' 断絶が起きるため、session 新規作成時に番兵を
    # 同時生成して構造的に防ぐ。-d で focus を奪わず、名前は素 'hold'（liveness 正準形
    # ':(wt-|admin-|admin$)'・fleet-monitor 完全一致・delivery-observe ':admin' のいずれにも非一致＝
    # 監視系の誤検出なし）。既に hold が居れば作らない（idempotent）。生成失敗は spawn 全体を失敗
    # させない（番兵は hardening・本体 window は生成済み）が、黙殺せず警告を出す。
    if ! tmux list-windows -t "=$TARGET_SESSION" -F '#{window_name}' 2>/dev/null | grep -qxF hold; then
        tmux new-window -d -t "=$TARGET_SESSION:" -n hold 'exec sleep infinity' \
            || echo "Warning: hold window を生成できませんでした（session '$TARGET_SESSION' は最後の kill-window で消滅しえます）" >&2
    fi
fi
exec 200>&-  # ロック解放

# Verify window was created
sleep 0.5
if ! tmux list-windows -t "=$TARGET_SESSION" -F '#{window_name}' 2>/dev/null | grep -qxF "$WINDOW_NAME"; then
    rm -f "$LAUNCHER"
    echo "Error: tmux window の作成に失敗しました" >&2
    exit 1
fi

echo "spawned → tmux window '$WINDOW_NAME' (session: $TARGET_SESSION)"

# --- window-manifest 書き出し (Phase 2 / #290) ---
# shellcheck source=./window-manifest.sh
source "$SCRIPT_DIR/window-manifest.sh" 2>/dev/null || true
if declare -f manifest_append_entry > /dev/null 2>&1; then
    _WM_SESSION="$TARGET_SESSION"
    # window_id(@N) も捕捉する。bd 階層 id（dotted、例 wt-un-3sh.3.5）は tmux の -t ターゲット構文
    # （`.` が window.pane 区切り）と衝突し、`-t <名前>` の send-keys/capture-pane が "can't find pane"
    # で失敗する（独立 socket で実証）。set-hook は **不変な window_id で参照**して dotted 名でも確実に
    # 紐づける（id 解決失敗時のみ名前へフォールバック＝後方互換）。
    # NB: 送達(session-comm.sh)・状態(session-state.sh)は resolve_target で名前→session:index を
    #     先に解決済み＝既に dot-safe。fleet-monitor の照合も name 文字列一致で dot-safe。
    _WM_INDEX=$(tmux list-windows -t "=$TARGET_SESSION" -F '#{window_name} #{window_index}' 2>/dev/null \
        | awk -v n="$WINDOW_NAME" '$1==n {print $2; exit}')
    _WM_WID=$(tmux list-windows -t "=$TARGET_SESSION" -F '#{window_id} #{window_name}' 2>/dev/null \
        | awk -v n="$WINDOW_NAME" '$2==n {print $1; exit}')
    manifest_append_entry "$WINDOW_NAME" "$_WM_SESSION" "${_WM_INDEX:-0}" \
        "$CWD" "$CWD" "wt" 2>/dev/null || true
    # kill / rename 時の tombstone hook（-t は dot-safe な window_id で参照）
    # WINDOW_NAME は英数字・ハイフン・ドット（bd 階層 id）のみで構成され、tombstone 引数は
    # printf '%q' 済み＝run-shell の単一引用符を破る文字は含まれない（'.' は引用符を破らない・安全）。
    _WM_SCRIPT=$(printf '%q' "$SCRIPT_DIR/window-manifest.sh")
    _WM_WINNAME=$(printf '%q' "$WINDOW_NAME")
    # フォールバック側も session 修飾で曖昧さを排除（window_id 解決失敗時のみ使用）
    _WM_HOOK_TGT="${_WM_WID:-$TARGET_SESSION:$WINDOW_NAME}"
    tmux set-hook -t "$_WM_HOOK_TGT" pane-died \
        "run-shell 'bash $_WM_SCRIPT tombstone $_WM_WINNAME'" 2>/dev/null || true
    # rename 時は旧 window_name を tombstone にする
    tmux set-hook -t "$_WM_HOOK_TGT" window-renamed \
        "run-shell 'bash $_WM_SCRIPT tombstone $_WM_WINNAME'" 2>/dev/null || true
fi

# プロンプトがなければここで終了（対話モード起動のみ）
if [[ -z "$PROMPT" ]]; then
    exit 0
fi

# --- inject-file --wait + read-back でプロンプトを送達（有界リトライ・ccs-ldt） ---
# 送達ロジックは deliver_prompt（inject-existing 経路と共通の SSOT）へ委譲する。
# 宛先は原則 session:window 修飾で渡す（bare 名だと resolve_target が全 session 横断の先頭一致で
# 解決し、別 session の同名 window へ誤送達しうるため。resolve_target は session:window を
# その session 内で session:index へ解決する＝dot-safe も維持）。
# 例外: 修飾 target は session 部・window 部の両方が送達層（resolve_target）の allowlist を
# 通るときだけ使い、外れる場合は bare 名送達へフォールバックする（警告付き・旧挙動そのもの）。
# - session 部: --session 省略時に解決した現在 session 名が安全集合（送達層 allowlist の strict
#   subset）外＝tmux 合法な '+' '@' '%' 等を含むと、送達層が reject し「window は生成済みなのに
#   偽失敗 exit 1」の回帰になる（--session 明示値は parse 時 validate 済みで必ず修飾送達）
# - window 部: --window-name 明示値が送達層の window allowlist 外（例 'foo@bar'）でも同じ偽失敗が
#   起きる。bare 送達側の resolve_target は allowlist 無しの名前一致解決＝旧挙動なら通るため
#   フォールバックが正しい（自動生成名 wt-/fk- slug・dotted bd id は常に両集合を通る）
_DELIVER_TGT="$TARGET_SESSION:$WINDOW_NAME"
if [[ ! "$TARGET_SESSION" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]] || [[ ! "$WINDOW_NAME" =~ ^[A-Za-z0-9_./-]+$ ]]; then
    _DELIVER_TGT="$WINDOW_NAME"
    echo "Warning: session/window 名が送達修飾の安全文字集合外のため bare window 名で送達します（session='$TARGET_SESSION' window='$WINDOW_NAME'。複数 session に同名 window がある場合は誤送達の可能性）" >&2
fi
if deliver_prompt "$_DELIVER_TGT" "$PROMPT"; then
    if $DELIVER_QUEUED; then
        echo "prompt injected → '$_DELIVER_TGT' (queued: busy 宛先の CC message queue へ着弾・再送なし)"
    else
        echo "prompt injected → '$_DELIVER_TGT'"
    fi
    exit 0
fi
echo "Error: プロンプトの送達に失敗しました（${CLD_INJECT_ATTEMPTS:-3}回試行・各${WAIT_TIMEOUT}秒待機／read-back 未確認）" >&2
exit 1
