# worker cell の self-test(selftest-*.local.sh 等) は untracked(コミットしない・docs/protocol.md §2)
*.local.sh

# worker env 健全性 probe の sentinel(scribe-env-probe.sh・untracked・コミットしない・sc-sau)
.scribe-envprobe

# spawn worker の worktree(.worktrees/spawn/<branch>) は ephemeral・コミットしない(sc-18q)
/.worktrees/

# admin cycle 境界 heartbeat の stamp(scripts/hooks/session-boundary-heartbeat.sh・sc-b6w)
# runtime 生成物(mtime が本体)ゆえ commit しない。scriptorium が .beads/last-sync を
# root .gitignore で除外しているのと同型。
/.beads/scribe-heartbeat

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/issues.jsonl
.beads/interactions.jsonl
embeddeddolt/

# Python bytecode (scripts/hooks/*.py = git-destructive-guard 等)
__pycache__/
*.pyc
