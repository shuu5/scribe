# worker cell の self-test(selftest-*.local.sh 等) は untracked(コミットしない・docs/protocol.md §2)
*.local.sh

# worker env 健全性 probe の sentinel(scribe-env-probe.sh・untracked・コミットしない・sc-sau)
.scribe-envprobe

# spawn worker の worktree(.worktrees/spawn/<branch>) は ephemeral・コミットしない(sc-18q)
/.worktrees/

# admin cycle 境界 heartbeat の stamp(scripts/hooks/session-boundary-heartbeat.sh・sc-b6w)
# runtime 生成物(mtime が本体)ゆえ commit しない。scriptorium が .beads/last-sync を
# root .gitignore で除外しているのと同型。
/.beads/scribe-heartbeat

# universal sync Layer2 の throttle marker(scripts/scribe-sync-push.sh・sc-fz5i)
# 最終 push 時刻(mtime が本体)の runtime 生成物ゆえ commit しない。scribe-heartbeat と同型。
/.beads/scribe-push-throttle

# cc-session subtree ledger 側の同型 runtime marker(sc-c4fr)
# 上の 2 行は root anchored(先頭 /)ゆえ cc-session/.beads/ には届かないため個別に指定。
# cc-session/.beads/.gitignore 側には足さない(あちらは bd/ccs 管理テンプレ＝所有混在を避ける)。
/cc-session/.beads/scribe-heartbeat
/cc-session/.beads/scribe-push-throttle

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/issues.jsonl
.beads/interactions.jsonl
embeddeddolt/

# Python bytecode (scripts/hooks/*.py = git-destructive-guard 等)
__pycache__/
*.pyc
